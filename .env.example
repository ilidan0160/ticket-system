# ==========================================
# CONFIGURACIÓN MAESTRA DEL SISTEMA DE TICKETS
# (Este archivo se usa tanto para Docker como para local)
# ==========================================

# ------------------------------------------
# 1. URLS Y CONEXIONES (Esenciales para Despliegue)
# ------------------------------------------
# Ya no necesitas poner tu IP aquí gracias al Reverse Proxy de Nginx.
# Estas variables universales funcionarán desde red local o internet.
FRONTEND_URL=http://localhost:3005
API_URL=/api
SOCKET_URL=/

# ------------------------------------------
# 2. BASE DE DATOS (PostgreSQL en Docker)
# ------------------------------------------
# Estas variables crean la DB y conectan el Backend a ella
DB_HOST=db
DB_PORT=5432
DB_NAME=ticket_system
DB_USER=postgres
DB_PASSWORD=tu_password_seguro_aqui

# ------------------------------------------
# 3. SEGURIDAD BACKEND
# ------------------------------------------
NODE_ENV=development
PORT=5000
JWT_SECRET=reemplaza_esta_cadena_con_algo_muy_seguro_y_largo
JWT_EXPIRE=30d
SESSION_SECRET=reemplaza_esta_sesion_tambien_por_seguridad

# ------------------------------------------
# 4. INTEGRACIÓN DE INTELIGENCIA ARTIFICIAL
# ------------------------------------------
# Clave de la API de Google Gemini para generación de reportes
GEMINI_API_KEY=tu_gemini_api_key_aqui

# ------------------------------------------
# 5. CONFIGURACIÓN OPCIONAL
# ------------------------------------------
# Telegram (Para recibir notificaciones al crear/reasignar tickets)
# TELEGRAM_BOT_TOKEN=tu_telegram_bot_token
# TELEGRAM_CHAT_ID=tu_telegram_chat_id

# Logging Nivel (debug, info, warn, error)
LOG_LEVEL=debug
